---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import logoSrc from "../assets/images/logo.png";
import Layout from "../layouts/main.astro";
import "../styles/global.css";

// Full Astro Component Syntax:
// https://docs.astro.build/basics/astro-components/

const logos = [
	{
		logo: "typescript-icon-round",
		name: "Typescript",
	},
	{
		logo: "react",
		name: "React",
	},
	{
		logo: "nextjs-icon",
		name: "Next.js",
	},
	{
		logo: "astro-icon",
		name: "Astro",
	},
	{
		logo: "tailwindcss-icon",
		name: "tailwindcss",
	},
	{
		logo: "nestjs",
		name: "nestjs",
	},
	{
		logo: "postgresql",
		name: "PostgreSQL",
	},
	{
		logo: "docker-icon",
		name: "Docker",
	},
	{
		logo: "aws",
		name: "AWS",
	},
];
---

<Layout content={{ title: 'Ezekiel Tarranza - Frontend Developer' }}>
  <div class="min-h-screen flex flex-col mx-auto max-w-[480px] space-y-6 pt-xl px-4 relative">
      <header>
        <div class="flex justify-between items-center overflow-hidden">
          <div>
            <h1 class="text-hero font-bold">Ezekiel Tarranza</h1>
            <p class="text-lg text-accent font-semibold">Frontend Developer</p>
            <div class="flex items-center mt-2 gap-sm">
              <a href="https://github.com/kielllll" target="_blank" rel="noopener noreferrer" aria-label="Github" class="hover:text-accent transition-colors duration-fast focus:outline-none focus:ring-2 focus:ring-accent-primary rounded-sm"><Icon name="logos:github-octocat" height={20} width={20} title='github' /></a>
              <a href="https://www.linkedin.com/in/ezekiel-tarranza/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="hover:text-accent transition-colors duration-fast focus:outline-none focus:ring-2 focus:ring-accent-primary rounded-sm"><Icon name="logos:linkedin-icon" height={20} width={20} title='linkedin' /></a>
            </div>
          </div>

           <Image src={logoSrc} alt="Portfolio logo" height={100} width={100} loading='eager' />
        </div>
      </header>

      <main class="space-y-6">
              <section class="space-y-4">
        <p class="leading-[1.6]">
          I build <strong class="text-accent">accessible</strong>, <strong class="text-accent">pixel-perfect</strong> digital experiences for the web.
          Passionate about crafting thoughtful interfaces that blend design
          with robust engineering.
        </p>

        <p class="leading-[1.6]">
          Currently, I'm a Frontend Developer
          at <a href="https://twoconnect.com.au/" target="_blank" class="text-accent underline underline-offset-3 hover:text-[#00e0ff] transition-colors duration-fast focus:outline-none focus:ring-2 focus:ring-accent-primary rounded-sm"><strong>Twoconnect</strong></a>, specializing
          in accessibility and functionality. I contribute to the creation and maintenance of UI
          components that power our plaform, ensuring our products meet web
          accessibility standards and best practices.
        </p>

        <p class="leading-[1.6]">
          In the past, I've had the opportunity to develop software accross a variety
          of settings. From <strong class="text-accent">start-ups</strong> and
          <strong class="text-accent">small digital product solutions</strong> to 
          <strong class="text-accent">large corporations</strong>.
        </p>
      </section>

      <section class="space-y-4">
        <h2 class="text-section text-primary font-semibold">Tech Stack</h2>

        <div class="flex items-center flex-wrap gap-sm">
          {logos.map(({logo, name}) => (
            <Icon name={`logos:${logo}`} height={32} width={32} title={name} />
          ))}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-section text-primary font-semibold">Projects</h2>
        
        <div class="flex flex-col justify-center items-center gap-md">
          <Icon name="tabler:settings-cog" height={52} width={52} />
          <p class="text-secondary">Work In Progress</p>
        </div>
      </section>
   
      </main>


      <footer class='text-center mt-auto mb-4 text-tertiary'>
        © 2025 Ezekiel Tarranza
      </footer>
		</div>
</Layout>
